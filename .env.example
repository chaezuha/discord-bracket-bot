# Bot token from the Discord Developer Portal (required)
DISCORD_TOKEN=

# Server ID for instant slash-command sync during development (optional)
#DEV_GUILD_ID=

# Maximum items per bracket, 2-64 (optional, default 32)
#MAX_ITEMS=32

# SQLite database location (optional, default ./data/brackets.db)
#DB_PATH=./data/brackets.db

# Directory for rotating log files (optional, default ./logs)
#LOG_DIR=./logs
